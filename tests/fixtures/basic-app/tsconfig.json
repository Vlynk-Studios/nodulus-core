{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@middleware/*": ["./src/middleware/*"],
      "@config/*": ["./src/config/*"],
      "@modules/*": ["./src/modules/*"]
    }
  },
  "include": ["src/**/*"]
}

{
  "name": "@vlynk-studios/nodulus-core",
  "version": "1.3.0",
  "description": "A lightweight structural layer for Express with native ESM hooks support.",
  "author": "Vlynk Studios & Keiver-dev",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nodulus": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vlynk-Studios/nodulus-core"
  },
  "keywords": [
    "express",
    "esm",
    "modular",
    "architecture",
    "typescript",
    "nodulus"
  ],
  "bugs": {
    "url": "https://github.com/Vlynk-Studios/nodulus-core/issues"
  },
  "homepage": "https://github.com/Vlynk-Studios/nodulus-core#readme",
  "peerDependencies": {
    "express": ">=5.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/acorn": "4.0.6",
    "@types/estree": "1.0.8",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "acorn": "8.16.0",
    "acorn-walk": "8.3.5",
    "eslint": "10.2.0",
    "express": "5.2.1",
    "supertest": "7.2.2",
    "tsup": "8.5.1",
    "typescript": "5.4.5",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "commander": "14.0.3",
    "comment-json": "4.6.2",
    "fast-glob": "3.3.3",
    "picocolors": "1.1.1"
  }
}
